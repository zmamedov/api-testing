        {
          "name": "PUT  Update Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Проверка, что ресурс обновился (Бизнес-логика)\r",
                  "pm.test(\"Resource was updated with new values\", () => {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    // ID остался прежним\r",
                  "    pm.expect(jsonData.id).to.eql(2);\r",
                  "\r",
                  "    // Заголовок теперь новый\r",
                  "    pm.expect(jsonData.title).to.eql(\"Update: New post title\");\r",
                  "\r",
                  "    // Тело изменилось\r",
                  "    pm.expect(jsonData.body).to.contain(\"New body\");\r",
                  "});\r",
                  "\r",
                  "const schema = {\r",
                  "    \"type\": \"object\",\r",
                  "    \"type\": \"object\",\r",
                  "    \"required\": [\"userId\", \"id\", \"title\", \"body\"],\r",
                  "    \"properties\": {\r",
                  "        \"userId\": { \"type\": \"number\" },\r",
                  "        \"id\": { \"type\": \"number\" },\r",
                  "        \"title\": { \"type\": \"string\" },\r",
                  "        \"body\": { \"type\": \"string\" }\r",
                  "    }\r",
                  "\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Updated post matches JSON Schema\", () => {\r",
                  "    pm.response.to.have.jsonSchema(schema);\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
